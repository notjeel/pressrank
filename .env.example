# ---------- Supabase (DB + Auth) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — server-only, NEVER expose to the client. Used by cron jobs + writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- AI provider (provider-agnostic) ----------
# Which adapter to use: "gemini" | "openai-compat"
AI_PROVIDER=gemini

# Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI-compatible (Groq, OpenRouter, local, etc.)
# Example Groq (free): base=https://api.groq.com/openai/v1  model=llama-3.3-70b-versatile
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# ---------- Data sources ----------
# YouTube Data API v3 (free quota): https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ---------- Anti-abuse ----------
# Cloudflare Turnstile (free): https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Set to "true" to bypass Turnstile in local dev
DISABLE_TURNSTILE=true

# ---------- Cron security ----------
# Shared secret required to call /api/cron/* . Vercel Cron sends it as a Bearer token.
CRON_SECRET=change-me-to-a-long-random-string
